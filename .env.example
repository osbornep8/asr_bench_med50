# Copy to .env (git-ignored) and fill in. Entry points load .env via envload.load_env().
# NOTE: keep real keys in .env, NEVER in this committed template.

# ── Local model storage (defaults to asr_bench/models/) ──────────────────────
ASR_MODELS_DIR=models

# ── Method A: glossary-conditioned LLM corrector (same model for ALL systems) ─
# Anthropic is the default. Set ANTHROPIC_API_KEY, or switch to an OpenAI model id.
ASR_CORRECT_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=          # only if ASR_CORRECT_MODEL is an OpenAI model

# ── Sarvam — REST sync STT (file ≤ 30s), model saaras:v3, BCP-47 codes (hi-IN) ─
SARVAM_API_KEY=
# SARVAM_STT_MODEL=saaras:v3      # or saarika:v2.5

# ── Smallest (Waves Pulse) — pre-recorded HTTP, raw bytes; model=pulse ────────
# multilingual (en, hi, ... — NO Kannada); keyword boosting is WS-only, not here.
SMALLEST_API_KEY=
# SMALLEST_STT_MODEL=pulse        # pulse-pro is English-only
# SMALLEST_STT_URL=https://api.smallest.ai/waves/v1/stt/

# ── Cartesia ─────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=
# CARTESIA_STT_MODEL=ink-whisper
# CARTESIA_VERSION=2025-04-16

# ── Gnani Prisma v2.5 (Vachana REST) — kn/hi/en/ml incl. Malayalam ───────────
# POST https://api.vachana.ai/stt/v3, header X-API-Key-ID, response field `transcript`.
GNANI_API_KEY=
# GNANI_STT_FORMAT=transcribe     # or "verbatim"
# GNANI_STT_URL=https://api.vachana.ai/stt/v3
